# ============================================
# FlowSphere Backend - Environment Variables
# ============================================

# --- Neon PostgreSQL ---
# Get this from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://username:password@ep-xxx.aws.neon.tech/flowsphere?sslmode=require"

# --- JWT ---
JWT_SECRET="change-this-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=5000
NODE_ENV="development"

# --- Frontend URL (for CORS and email links) ---
FRONTEND_URL="http://localhost:3000"

# --- Brevo (Email Verification) ---
# Sign up at: https://app.brevo.com → SMTP & API → SMTP
# Settings → SMTP & API → Generate SMTP key
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your-brevo-login-email@example.com"
BREVO_SMTP_PASS="your-brevo-smtp-key"
EMAIL_FROM_NAME="FlowSphere"
EMAIL_FROM_ADDRESS="noreply@flowsphere.dev"
